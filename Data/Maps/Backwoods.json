{
    "$schema": "https://smapi.io/schemas/content-patcher.json",
    "Changes": [
        {
            "Action": "Load",
            "Target": "Maps/{{ModId}}_BackwoodsExtensionLeft",
            "FromFile": "Assets/Maps/BackwoodsExtensionLeft.tmx",
        },
        {
            "Action": "EditMap",
            "Target": "Maps/Backwoods",
            "FromFile": "Assets/Maps/BackwoodsExtensionRight.tmx",
            "ToArea": {
                "X": 50,
                "Y": 0,
                "Width": 4,
                "Height": 40
            }
        },
        {
            "Action": "EditData",
            "Target": "Data/Locations",
            "Entries": {
                "{{ModId}}_BackwoodsExtensionLeft": {
                    "DisplayName": "BackwoodsExtensionLeft",
                    "DefaultArrivalTile": "10, 18",
                    "CreateOnLoad": {
                        "MapPath": "Maps/{{ModId}}_BackwoodsExtensionLeft"
                    }
                }
            }
        },

    ]
}


